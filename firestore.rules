rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Kullanıcılar - sadece giriş yapmış kullanıcılar okuyabilir, yazma sadece admin/superadmin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Duyurular - herkes okuyabilir, admin ve superadmin yazabilir
    match /duyurular/{duyuruId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin'];
    }

    // Projeler
    match /projeler/{projeId} {
      allow read: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin', 'gerceklestirmeci']);
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (resource.data.userId == request.auth.uid ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'gerceklestirmeci');
      allow delete: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }

    // Referans verileri
    match /referans/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
